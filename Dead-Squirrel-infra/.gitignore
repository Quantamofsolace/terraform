# Terraform state — never commit
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Var files with real values — never commit
terraform.tfvars
*.auto.tfvars

# Crash logs
crash.log
crash.*.log

# Sensitive overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# IDE
.idea/
.vscode/
*.swp
.DS_Store
